<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_below_cost_reject_wizard_form" model="ir.ui.view">
        <field name="name">below.cost.reject.wizard.form</field>
        <field name="model">below.cost.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Below-Cost Approval">
                <group>
                    <field name="sale_order_id" readonly="1"/>

                    <field name="reject_reason_id"/>
                    <field name="reject_note" placeholder="Enter details..."/>
                </group>

                <footer>
                    <button string="Reject"
                            type="object"
                            name="action_submit"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>