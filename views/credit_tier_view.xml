<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================= -->
    <!-- LIST (TREE) -->
    <!-- ========================= -->
    <record id="view_credit_tier_list" model="ir.ui.view">
        <field name="name">credit.tier.list</field>
        <field name="model">credit.tier</field>
        <field name="arch" type="xml">
            <list string="Credit Tiers" default_order="sequence, name">
                <field name="sequence" widget="handle" optional="show"/>
                <field name="name"/>
                <field name="code" optional="show"/>
                <field name="default_credit_limit"/>
                <field name="company_id" optional="show"/>
                <field name="color" widget="color_picker" optional="hide"/>
                <field name="active" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ========================= -->
    <!-- FORM -->
    <!-- ========================= -->
    <record id="view_credit_tier_form" model="ir.ui.view">
        <field name="name">credit.tier.form</field>
        <field name="model">credit.tier</field>
        <field name="arch" type="xml">
            <form string="Credit Tier">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Gold"/>
                        </h1>
                        <div class="text-muted">
                            <field name="code" placeholder="GOLD" class="o_inline"/>
                        </div>
                    </div>

                    <group>
                        <group string="Tier Settings">
                            <field name="active"/>
                            <field name="sequence"/>
                            <field name="company_id"/>
                            <field name="color" widget="color_picker"/>
                        </group>

                        <group string="Credit Policy">
                            <field name="default_credit_limit"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Notes">
                            <field name="note" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- KANBAN (Odoo 18 style) -->
    <!-- ========================= -->
<record id="view_credit_tier_kanban" model="ir.ui.view">
    <field name="name">credit.tier.kanban</field>
    <field name="model">credit.tier</field>
    <field name="arch" type="xml">
        <kanban sample="1" class="o_kanban_small_column">
            <field name="name"/>
            <field name="code"/>
            <field name="color"/>
            <field name="default_credit_limit"/>
            <field name="active"/>

            <templates>
                <t t-name="kanban-box">
                    <div t-attf-class="o_kanban_record o_kanban_color_#{record.color.raw_value} oe_kanban_global_click">

                        <widget name="web_ribbon"
                                title="Archived"
                                bg_color="text-bg-danger"
                                invisible="active"/>

                        <!-- Header -->
                        <div class="o_kanban_record_top">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <t t-esc="record.name.value"/>
                                </strong>
                                <div class="text-muted" t-if="record.code.value">
                                    <t t-esc="record.code.value"/>
                                </div>
                            </div>
                        </div>

                        <!-- Body -->
                        <div class="o_kanban_record_body mt-2">

                            <!-- Clean default limit display -->
                            <div class="fw-semibold">
                                Default Limit:
                                <span class="text-primary">
                                    <t t-esc="record.default_credit_limit.value"/>
                                </span>
                            </div>

                        </div>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>



    <!-- ========================= -->
    <!-- ACTION -->
    <!-- ========================= -->
    <record id="action_credit_tier" model="ir.actions.act_window">
        <field name="name">Credit Tiers</field>
        <field name="res_model">credit.tier</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- ===================== -->
    <!-- Menus (Accounting) -->
    <!-- ===================== -->
    <menuitem id="menu_credit_control_root"
              name="Credit Control"
              parent="account.menu_finance_configuration"
              sequence="65"
              groups="account.group_account_manager"/>

    <menuitem id="menu_credit_tier"
              name="Credit Tiers"
              parent="menu_credit_control_root"
              action="action_credit_tier"
              sequence="10"
              groups="account.group_account_manager"/>

</odoo>
